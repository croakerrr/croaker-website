{
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/save-post", 
      "destination": "/api/admin/save-post"
    },
    {
      "source": "/admin/save-project",
      "destination": "/api/admin/save-project"  
    },
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    }
  ]
}